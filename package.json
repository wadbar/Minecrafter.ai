{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "NODE_ENV=production node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist .vite .cache node_modules/.cache",
    "lint": "tsc --noEmit && eslint src/ || true",
    "setup": "npm ci && npm run build",
    "update:sys": "npm update && npm run clean && npm install && npm run build",
    "optimize": "NODE_ENV=production npm dedupe && npm run build"
  },
