# =========================================================================
# MINECRAFTER AI - ENVIRONMENT VARIABLES
# =========================================================================

# VITE CONFIGURATION (CLIENT SIDE)
# Variables exposed to the frontend MUST start with VITE_

# SERVER CONFIGURATION (BACKEND)
NODE_ENV=development
PORT=3000

# GEMINI AI
# API Key for Google Gemini (Vertex AI / Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# FIREBASE INTEGRATION (Set up via platform tools or service account)
# FIREBASE_PROJECT_ID=...
